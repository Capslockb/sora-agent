# Sora VOIP Bridge Environment Variables
# Copy to ~/.config/sora/voip.env and fill in values

# Asterisk ARI
SORA_ARI_URL=http://localhost:8088/ari
SORA_ARI_USER=sora
SORA_ARI_PASSWORD=changeme
SORA_ARI_APP=sora
SORA_EXTERNAL_MEDIA_HOST=0.0.0.0
SORA_EXTERNAL_MEDIA_PORT=5000

# Dograh (REQUIRED)
SORA_DOGRAH_WS_URL=ws://your-dograh-host:8080/gemini
SORA_DOGRAH_API_KEY=

# Gemini Live
SORA_GEMINI_MODEL=gemini-2.0-flash-exp
SORA_GEMINI_VOICE=Puck
SORA_GEMINI_TEMPERATURE=0.7

# HTTP API
SORA_HTTP_HOST=0.0.0.0
SORA_HTTP_PORT=18944