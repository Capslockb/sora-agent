# Voice Agent production environment template
# Copy this file to .env.production on the deployment host.
# Do not commit the real .env.production file.

# ============================================================
# REMOTE IMAGE DEPLOYMENT
# ============================================================

# Required for docker-compose.deploy.yml. Use the image produced by the Deploy
# workflow, usually ghcr.io/<owner>/<repo>:sha-<commit> or :latest.
IMAGE_REF=ghcr.io/<owner>/<repo>:latest

# Public HTTPS origin for the deployed app. Use one exact origin; do not use *
# in production. Production startup and health posture treat missing origins,
# wildcard origins, invalid origins, and localhost-only origins as unsafe.
CORS_ORIGIN=https://voice.example.com
ALLOW_LOCALHOST_PRODUCTION_CORS=false

# Explicit JSON body limit for API routes. Raise only with a documented reason.
JSON_BODY_LIMIT=128kb

# The container listens on SERVER_PORT. HOST_PORT is the host-side published
# port used by Docker Compose.
SERVER_PORT=3001
HOST_PORT=3001
NODE_ENV=production

# ============================================================
# PUBLIC BUILD-TIME FRONTEND VARIABLES
# ============================================================
# These VITE_* values are compiled into the frontend bundle when the image is
# built. For Coolify repository builds, set them in the application build
# environment. For GHCR image deployments, rebuild and republish the image when
# these values change.

VITE_API_BASE_URL=/
VITE_NODE_ENV=production
VITE_DEFAULT_PROVIDER=elevenlabs

VITE_ELEVENLABS_ENABLED=true
VITE_ELEVENLABS_SDK_ENABLED=true
VITE_ELEVENLABS_AGENT_ID=CHANGE_ME_ELEVENLABS_AGENT_ID

VITE_XAI_ENABLED=true
VITE_XAI_MODEL=grok-2-public
VITE_XAI_VOICE=Ara
VITE_XAI_INSTRUCTIONS=You are a helpful voice assistant powered by Grok. Keep responses conversational and concise.

VITE_OPENAI_ENABLED=true
VITE_OPENAI_MODEL=gpt-realtime
VITE_OPENAI_VOICE=alloy
VITE_OPENAI_INSTRUCTIONS=You are a helpful voice assistant. Keep responses conversational and concise.
# Frontend visibility flag for the OpenAI Translation tab. This is compiled
# into the browser bundle; rebuild the image when changing it. The backend
# mints translation client secrets with server-side OPENAI_API_KEY.
# See docs/OPENAI_TRANSLATION_DEMO.md for run steps and browser limits.
VITE_OPENAI_TRANSLATION_ENABLED=false
# Optional frontend max-session guard in minutes. Default is 30; values above
# the hard 120-minute maximum are capped.
VITE_OPENAI_TRANSLATION_MAX_SESSION_MINUTES=30

VITE_ULTRAVOX_ENABLED=true
VITE_ULTRAVOX_VOICE=Mark
VITE_ULTRAVOX_INSTRUCTIONS=You are a helpful voice assistant. Keep responses conversational and concise.
VITE_ULTRAVOX_MODEL=

VITE_VAPI_ENABLED=true
VITE_VAPI_WEB_TOKEN=CHANGE_ME_VAPI_PUBLIC_WEB_TOKEN
VITE_VAPI_API_URL=
VITE_VAPI_ASSISTANT_ID=
VITE_VAPI_VOICE=paula
VITE_VAPI_MODEL=gpt-4o-mini
VITE_VAPI_SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses conversational and concise.
VITE_VAPI_FIRST_MESSAGE=Hello! How can I help you today?

VITE_RETELL_ENABLED=true
VITE_RETELL_AGENT_ID=CHANGE_ME_RETELL_AGENT_ID

# Gemini browser sessions currently require special handling because the raw
# server GEMINI_API_KEY must never be returned to browsers in production. Keep
# Gemini disabled unless a browser-safe Gemini token exchange is available.
VITE_GEMINI_ENABLED=false
VITE_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
VITE_GEMINI_VOICE=Zephyr
VITE_GEMINI_INSTRUCTIONS=You are a helpful voice assistant. Keep responses conversational and concise.

VITE_ERROR_TRACKING_ENABLED=false
VITE_ERROR_TRACKING_PROVIDER=console

VITE_WIDGET_ORB_COLOR_1=#fbbf24
VITE_WIDGET_ORB_COLOR_2=#a78bfa
VITE_WIDGET_VARIANT=compact
VITE_WIDGET_ACTION_TEXT=Talk to AI
VITE_WIDGET_START_CALL_TEXT=Start Conversation
VITE_WIDGET_END_CALL_TEXT=End Conversation
VITE_WIDGET_LISTENING_TEXT=Listening...
VITE_WIDGET_SPEAKING_TEXT=Speaking...
VITE_WIDGET_AVATAR_URL=
VITE_WIDGET_OVERRIDE_VOICE_ID=
VITE_WIDGET_OVERRIDE_LANGUAGE=
VITE_WIDGET_OVERRIDE_FIRST_MESSAGE=Hello! How can I help you today?

# ============================================================
# RUNTIME SERVER SECRETS
# ============================================================
# These values are injected only when the container starts. Never expose them
# as Docker build args, VITE_* variables, or frontend environment variables.
# At least one provider credential is required for a useful production deploy.

ELEVENLABS_API_KEY=CHANGE_ME_ELEVENLABS_API_KEY
XAI_API_KEY=CHANGE_ME_XAI_API_KEY
# Required for OpenAI voice sessions and translation client-secret minting.
# Server-side only: never expose this as a VITE_* variable, build arg, or
# browser runtime config value.
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
ULTRAVOX_API_KEY=CHANGE_ME_ULTRAVOX_API_KEY
RETELL_API_KEY=CHANGE_ME_RETELL_API_KEY
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY

# Optional xAI server setting.
XAI_SESSION_EXPIRY_SECONDS=300

# ============================================================
# OBSERVABILITY
# ============================================================
# Request logs are written to container stdout. Metrics are process-local and
# reset on container restart. Leave both enabled unless your host policy
# requires disabling one of these endpoints.

LOG_LEVEL=info
REQUEST_LOGGING_ENABLED=true
METRICS_ENABLED=true

# Configure these in your uptime provider or hosting platform. They are
# documented here so deployment owners capture the chosen monitor and alert
# route next to the runtime configuration.
UPTIME_MONITOR_URL=https://voice.example.com/api/health
UPTIME_ALERT_DESTINATION=ops@example.com

# ============================================================
# GITHUB ACTIONS DEPLOYMENT SETTINGS
# ============================================================
# Configure these in GitHub repository or environment variables/secrets, not in
# the container environment file:
#
# Variables:
#   DEPLOY_WEBHOOK_URL
#   DEPLOY_SSH_HOST
#   DEPLOY_SSH_USER
#   DEPLOY_PATH=/opt/voice-agent
#   HEALTH_CHECK_URL=https://voice.example.com/api/health
#
# Secrets:
#   DEPLOY_WEBHOOK_TOKEN
#   DEPLOY_SSH_KEY
