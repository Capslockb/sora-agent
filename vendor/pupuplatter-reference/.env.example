# Voice Agent Multi-Provider Configuration
# Copy this file to .env and fill in your actual values
# SECURITY: Never commit .env to git - it's already in .gitignore
# Production deploys should start from .env.production.example instead.
# That template separates build-time public VITE_* values from runtime
# server secrets used by Coolify, GHCR image, and SSH deployments.

# ============================================================
# PROVIDER SELECTION (CLIENT-SIDE)
# ============================================================
# Controls which voice providers are enabled in the tab UI
# Set to "true" to show provider tab, "false" or omit to hide

# ElevenLabs Widget (pre-built embed from CDN)
VITE_ELEVENLABS_ENABLED=true

# ElevenLabs SDK (custom React components with @elevenlabs/react)
VITE_ELEVENLABS_SDK_ENABLED=true

# xAI Grok voice provider
VITE_XAI_ENABLED=true

# OpenAI Realtime API voice provider
VITE_OPENAI_ENABLED=true

# OpenAI live translation provider
# Public frontend build-time visibility flag only. Set before Vite or Docker
# builds. Translation client secrets are minted by the backend with server-side
# OPENAI_API_KEY. See docs/OPENAI_TRANSLATION_DEMO.md.
VITE_OPENAI_TRANSLATION_ENABLED=false

# Optional frontend demo/test max-session guard in minutes for OpenAI Translation.
# Default is 30 minutes. Values above the hard 120-minute maximum are capped in
# the browser guard. This is not a runtime secret and changing it in production
# requires a frontend rebuild.
VITE_OPENAI_TRANSLATION_MAX_SESSION_MINUTES=30

# Ultravox voice provider
VITE_ULTRAVOX_ENABLED=true

# Vapi voice provider (no backend required - uses public web token)
VITE_VAPI_ENABLED=true

# Retell AI voice provider (backend required for access tokens)
VITE_RETELL_ENABLED=true

# Gemini Live API voice provider (backend required for ephemeral tokens)
VITE_GEMINI_ENABLED=false

# Default provider tab (elevenlabs | elevenlabs-sdk | xai | openai | ultravox | vapi | retell | gemini)
VITE_DEFAULT_PROVIDER=elevenlabs

# ============================================================
# ELEVENLABS CONFIGURATION
# ============================================================

# ElevenLabs Agent ID for voice conversations (used by both Widget and SDK)
# Get this from your ElevenLabs dashboard: https://elevenlabs.io/app/conversational-ai
VITE_ELEVENLABS_AGENT_ID=agent_your_agent_id_here

# ============================================================
# ELEVENLABS WIDGET CUSTOMIZATION (only affects Widget tab)
# ============================================================

# Orb gradient colors (hex format)
VITE_WIDGET_ORB_COLOR_1=#fbbf24
VITE_WIDGET_ORB_COLOR_2=#a78bfa

# Widget variant: "compact" (floating orb) or "expanded" (full panel)
VITE_WIDGET_VARIANT=compact

# Widget Text Labels
VITE_WIDGET_ACTION_TEXT=Talk to AI
VITE_WIDGET_START_CALL_TEXT=Start Conversation
VITE_WIDGET_END_CALL_TEXT=End Conversation
VITE_WIDGET_LISTENING_TEXT=Listening...
VITE_WIDGET_SPEAKING_TEXT=Speaking...

# Optional: Custom avatar image URL (leave empty to use orb)
VITE_WIDGET_AVATAR_URL=

# Optional: Override voice/language at runtime
VITE_WIDGET_OVERRIDE_VOICE_ID=
VITE_WIDGET_OVERRIDE_LANGUAGE=

# Override first message (useful when agent has dynamic variables)
VITE_WIDGET_OVERRIDE_FIRST_MESSAGE=Hello! How can I help you today?

# ============================================================
# XAI (GROK) CONFIGURATION
# ============================================================

# xAI Model for Realtime API
# See: https://docs.x.ai/docs/models
VITE_XAI_MODEL=grok-2-public

# xAI Voice Selection
# Available voices: "Ara", "Eve", "Leo", "Rex", "Sal" (default: Ara)
# See: https://docs.x.ai/docs/guides/voice/agent
VITE_XAI_VOICE=Ara

# xAI System Instructions (customize the AI's personality)
VITE_XAI_INSTRUCTIONS=You are a helpful voice assistant powered by Grok. Keep responses conversational and concise since they will be spoken aloud.

# ============================================================
# OPENAI CONFIGURATION
# ============================================================

# OpenAI Model for Realtime API
# Available: gpt-realtime (Aug 2025), gpt-4o-realtime-preview-2024-12-17
# See: https://platform.openai.com/docs/models
VITE_OPENAI_MODEL=gpt-realtime

# OpenAI Voice Selection
# Available voices: "alloy", "ash", "ballad", "coral", "echo", "sage", "shimmer", "verse" (default: alloy)
# See: https://platform.openai.com/docs/guides/realtime
VITE_OPENAI_VOICE=alloy

# OpenAI System Instructions (customize the AI's personality)
VITE_OPENAI_INSTRUCTIONS=You are a helpful voice assistant. Keep responses conversational and concise.

# ============================================================
# ULTRAVOX CONFIGURATION
# ============================================================

# Ultravox Voice Selection
# Available voices: "Mark" (default), additional voices TBD
# See: https://docs.ultravox.ai/
VITE_ULTRAVOX_VOICE=Mark

# Ultravox System Instructions (customize the AI's personality)
VITE_ULTRAVOX_INSTRUCTIONS=You are a helpful voice assistant. Keep responses conversational and concise.

# Ultravox Model (optional - uses default if not specified)
# VITE_ULTRAVOX_MODEL=fixie-ai/ultravox

# ============================================================
# VAPI CONFIGURATION (No backend required - frontend only)
# ============================================================

# Vapi Web Token (public key - safe to expose in frontend)
# Get this from: https://dashboard.vapi.ai/ > API Keys > Public Key
VITE_VAPI_WEB_TOKEN=your-vapi-web-token

# Optional: Custom API endpoint (defaults to https://api.vapi.ai)
# VITE_VAPI_API_URL=https://api.vapi.ai

# Optional: Pre-created Assistant ID (if using Vapi dashboard to create assistants)
# If set, this will be used instead of inline configuration
# VITE_VAPI_ASSISTANT_ID=your-assistant-id

# Vapi Voice Selection (ElevenLabs voice IDs)
# Available voices: "paula", "jennifer", "sarah", "adam", etc.
# See: https://docs.vapi.ai/
VITE_VAPI_VOICE=paula

# Vapi Model Selection
# Available: "gpt-3.5-turbo", "gpt-4o-mini", "gpt-4o", etc.
VITE_VAPI_MODEL=gpt-4o-mini

# Vapi System Prompt (customize the AI's personality)
VITE_VAPI_SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses conversational and concise.

# Vapi First Message (greeting when call starts)
VITE_VAPI_FIRST_MESSAGE=Hello! How can I help you today?

# ============================================================
# RETELL AI CONFIGURATION (Backend required for access tokens)
# ============================================================

# Retell Agent ID (pre-created in Retell dashboard)
# Get this from: https://dashboard.retellai.com/
VITE_RETELL_AGENT_ID=your-retell-agent-id

# Optional: Retell voice/model settings are configured in the Retell dashboard
# The agent configuration (voice, LLM, prompts) is managed server-side

# ============================================================
# GEMINI LIVE API CONFIGURATION (Backend required for ephemeral tokens)
# ============================================================

# Gemini Model for Live API
# Available: gemini-2.5-flash-native-audio-preview-12-2025 (recommended)
# See: https://ai.google.dev/gemini-api/docs/live
VITE_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Gemini Voice Selection (30 HD voices available)
# Available voices: "Zephyr", "Puck", "Charon", "Kore", "Fenrir", "Leda", "Orus", "Aoede",
#   "Callirrhoe", "Autonoe", "Enceladus", "Iapetus", "Umbriel", "Algieba", "Despina",
#   "Erinome", "Algenib", "Rasalgethi", "Laomedeia", "Achernar", "Alnilam", "Schedar",
#   "Gacrux", "Pulcherrima", "Achird", "Zubenelgenubi", "Vindemiatrix", "Sadachbia",
#   "Sadaltager", "Sulafat"
# See: https://ai.google.dev/gemini-api/docs/speech-generation
VITE_GEMINI_VOICE=Zephyr

# Gemini System Instructions (customize the AI's personality)
VITE_GEMINI_INSTRUCTIONS=You are a helpful voice assistant. Keep responses conversational and concise.

# ============================================================
# COMMON CLIENT-SIDE VARIABLES
# ============================================================

# API base URL for the backend server.
# Local Vite development usually uses http://localhost:3001.
# Combined Docker production should use / for same-origin API calls.
# Split frontend/backend hosting should use the absolute backend URL.
VITE_API_BASE_URL=http://localhost:3001

# Frontend mode flag
VITE_NODE_ENV=development

# ============================================================
# SERVER-SIDE VARIABLES (NOT exposed to client - secure)
# ============================================================
# IMPORTANT: These keys are server-side only and never sent to the browser
# The backend uses these to generate ephemeral tokens for secure connections

# ElevenLabs API Key
# Get this from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here

# xAI API Key
# Get this from: https://console.x.ai/
XAI_API_KEY=xai-your_xai_api_key_here

# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
# Required for OpenAI Realtime voice conversations and translation client-secret minting.
# Server-side only: do not expose this as VITE_OPENAI_API_KEY or any other VITE_* variable.
OPENAI_API_KEY=sk-your_openai_api_key_here

# Ultravox API Key
# Get this from: https://ultravox.ai/ (API settings)
# Required for Ultravox voice conversations
ULTRAVOX_API_KEY=your_ultravox_api_key_here

# Retell AI API Key (Secret)
# Get this from: https://dashboard.retellai.com/ > API Keys
# Required for creating web call access tokens (backend generates per-call tokens)
RETELL_API_KEY=key_your_retell_api_key_here

# Gemini API Key
# Get this from: https://aistudio.google.com/apikey
# Required for generating ephemeral tokens for Live API connections
GEMINI_API_KEY=your_gemini_api_key_here

# Note: Vapi does NOT require a server-side API key
# Vapi uses a public web token (VITE_VAPI_WEB_TOKEN) directly in the frontend

# ============================================================
# SERVER CONFIGURATION
# ============================================================

SERVER_PORT=3001
# Host port used by docker-compose.yml for local production testing
HOST_PORT=3001

# Development default: Vite frontend on http://localhost:8082.
# Combined Docker default: http://localhost:3001.
# Production domain example: https://voice.example.com.
CORS_ORIGIN=http://localhost:8082

# Local Docker production smoke tests may use localhost-only CORS origins.
# Keep this unset or false for remote production deployments.
ALLOW_LOCALHOST_PRODUCTION_CORS=true

# ============================================================
# DOCKER PRODUCTION NOTES
# ============================================================
#
# Local production smoke test:
#   npm run docker:prod
#
# Docker Compose reads this .env file for interpolation, but
# docker-compose.yml only injects the runtime variables it enumerates.
#
# Build-time frontend variables:
#   - Only VITE_* values are passed as Docker build args.
#   - VITE_API_BASE_URL=/ is recommended for combined same-origin Docker
#     production so browser API calls stay on the current host.
#   - Use an absolute VITE_API_BASE_URL only for split frontend/backend hosting.
#
# Runtime server variables:
#   - Provider API keys below are injected at container runtime only.
#   - Do not add ELEVENLABS_API_KEY, XAI_API_KEY, OPENAI_API_KEY,
#     ULTRAVOX_API_KEY, RETELL_API_KEY, or GEMINI_API_KEY as Docker build args.
#
# Local Docker examples:
#   HOST_PORT=3001
#   SERVER_PORT=3001
#   CORS_ORIGIN=http://localhost:3001
#   ALLOW_LOCALHOST_PRODUCTION_CORS=true
#   VITE_API_BASE_URL=/

# xAI-specific server config (optional)
# XAI_SESSION_EXPIRY_SECONDS=300

# ===========================================
# ngrok Tunnel Configuration (Demo Mode)
# ===========================================
# ngrok exposes the local production server via HTTPS for demos
# Get authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
#
# Demo mode is activated when running `npm run demo`
# The demo script automatically:
#   - Builds the frontend into dist/
#   - Starts Express in production mode on port 3001
#   - Starts one ngrok tunnel to port 3001
#   - Generates dist/config.js for same-origin API calls
#   - These files are ephemeral (deleted on shutdown, gitignored)
#
# DEMO_MODE is set automatically by configure-urls.sh during demo startup
# Do not set manually - it is injected at runtime
# DEMO_MODE=true
#
# Required:
NGROK_AUTHTOKEN=<your-ngrok-authtoken-here>
#
# Optional - Custom Domain (paid plans only):
# Create a custom domain in the ngrok dashboard, then set it here
# Free tier uses random subdomains (e.g., abc123.ngrok-free.app)
# Reserve domains at: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=<your-demo-domain>.ngrok.io
NGROK_BACKEND_DOMAIN=<your-backend-demo-domain>.ngrok.io
#
# Optional - Basic Auth (password protection for demos):
# When set, users must enter username/password to access the tunnel
# Useful for protecting demos from unauthorized access
NGROK_AUTH_USER=
NGROK_AUTH_PASS=
#
# Optional - Web Inspector Port (default: 4041):
# ngrok provides a web UI for inspecting traffic at http://localhost:PORT
# Using 4041 avoids conflicts with default 4040 if running multiple instances
NGROK_INSPECTOR_PORT=4041
#
# Optional - ngrok API Key (for programmatic tunnel management):
# Get from: https://dashboard.ngrok.com/api
NGROK_API_KEY=<your-ngrok-api-key-here>
