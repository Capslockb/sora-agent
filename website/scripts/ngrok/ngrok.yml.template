# ngrok Configuration for Voice-Agent-PuPuPlatter
# Config file version 2 (for ngrok CLI v3)
#
# TEMPLATE FILE - Do not edit ngrok.yml directly!
# This template is processed by generate-ngrok-config.sh
# which substitutes __VAR__ placeholders with environment values.
#
# ARCHITECTURE: Single-tunnel production mode
#   - Express serves both API routes AND static frontend (from dist/)
#   - One ngrok tunnel to port 3001 handles everything
#   - Same-origin = no CORS issues = basic_auth works with preflight
#
# Environment Variables Required:
#   NGROK_AUTHTOKEN - Your ngrok auth token (required)
#
# Environment Variables Optional:
#   NGROK_DOMAIN - Custom domain (paid plans only, e.g., myapp.ngrok.dev)
#   NGROK_AUTH_USER - Basic auth username for password protection
#   NGROK_AUTH_PASS - Basic auth password for password protection
#   NGROK_INSPECTOR_PORT - Web inspector port (default: 4041)
#
# Usage:
#   ./generate-ngrok-config.sh  # generates ngrok.yml from this template
#   ngrok start --all --config scripts/ngrok/ngrok.yml

version: "2"

# Web inspector configuration
# Port 4041 avoids conflicts with default 4040 if running multiple ngrok instances
web_addr: localhost:__NGROK_INSPECTOR_PORT__

tunnels:
  # Single tunnel - Express server in production mode
  # Serves both the frontend (from dist/) and API routes
  # This eliminates CORS issues, allowing basic_auth to work
  demo:
    proto: http
    addr: 3001
__DEMO_DOMAIN__
__DEMO_BASIC_AUTH__
